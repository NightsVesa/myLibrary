# Copy this file to .env and fill in the values you need.
# If LLM_API_KEY is empty, LLM-powered wiki ingest and chat are disabled.

LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# HTTP and retry behavior
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_THINKING=false

# Wiki ingest/query tuning
WIKI_RETRIEVAL_TOP_N=5
WIKI_QUERY_TOP_N=6
WIKI_QUERY_RELATED_MAX=4
WIKI_QUERY_CONTEXT_MAX_CHARS=30000
WIKI_QUERY_PAGE_MAX_CHARS=8000
WIKI_QUERY_RAW_SOURCE_MAX=2
WIKI_QUERY_RAW_SOURCE_MAX_CHARS=12000
WIKI_INDEX_SUMMARY_LEN=80
WIKI_MAX_EXTRACT_ITEMS=15
WIKI_CANDIDATE_TOP_N=20
WIKI_DEEP_READ_MAX=8
WIKI_DEEP_READ_MAX_CHARS=12000

# Wiki health-check tuning
WIKI_LINT_MAX_CHARS=16000
WIKI_LINT_STALE_DAYS=90
